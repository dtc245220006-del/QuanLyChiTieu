@model QuanLyChiTieu.Models.Budget

@{
    ViewData["Title"] = "Thiết lập Ngân sách";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0" style="border-radius: 20px;">
                <div class="card-header bg-danger text-white text-center py-3" style="border-radius: 20px 20px 0 0;">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-piggy-bank"></i> Lập Kế Hoạch Chi Tiêu</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>


                        <div class="mb-3">
                            <label class="form-label fw-bold">Áp dụng cho danh mục</label>
                            <select asp-for="CategoryId" class="form-select border-danger" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Hạn mức tối đa (VNĐ)</label>
                            <input asp-for="LimitAmount" class="form-control border-danger" type="number" placeholder="Ví dụ: 2000000" required />
                            <span asp-validation-for="LimitAmount" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mục tiêu/Ghi chú</label>
                            <textarea class="form-control border-danger" rows="2" placeholder="Ví dụ: Tiền ăn cả tháng 3..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold shadow">Kích hoạt ngân sách</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>