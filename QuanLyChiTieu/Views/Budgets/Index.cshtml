@model IEnumerable<QuanLyChiTieu.Models.Budget>
<h1>Quản lí ngân sách</h1>

<p>
    <a asp-action="Create">Tạo mới</a>
</p>
<table class="table table-hover mt-2">
    <thead>
        <tr>
            <th>
                Số tiền giới hạn
            </th>
            <th>
                Ngày/tháng
            </th>
            <th>
               Danh mục
            </th>
            <th>
                Khách hàng
            </th>           
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.LimitAmount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MonthYear)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.CategoryId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.User.UserId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.BudgetId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.BudgetId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.BudgetId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
