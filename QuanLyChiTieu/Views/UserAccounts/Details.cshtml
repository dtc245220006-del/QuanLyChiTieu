@model QuanLyChiTieu.Models.UserAccount

@{
    ViewData["Title"] = "Chi tiết thành viên";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center mb-3">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width:56px;height:56px;border:1px solid #eee;">
                    <i class="bi bi-person-fill fs-4 text-success"></i>
                </div>
                <div>
                    <h4 class="mb-0">@Model.Username</h4>
                    <small class="text-muted">@Model.UserId</small>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="text-muted small">Email</label>
                    <div class="fw-medium">@Model.Email</div>
                </div>
                <div class="col-md-3">
                    <label class="text-muted small">Role</label>
                    <div class="fw-medium">@Model.Role</div>
                </div>
                <div class="col-md-3">
                    <label class="text-muted small">Mật khẩu</label>
                    <div class="password-mask">@(String.IsNullOrEmpty(Model.Password) ? "••••••••" : new string('•', Math.Max(6, Model.Password.Length)))</div>
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-end">
                <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-warning me-2"><i class="bi bi-pencil"></i> Sửa</a>
                <a asp-action="Index" class="btn btn-secondary me-2"><i class="bi bi-arrow-left"></i> Quay lại</a>
                <form asp-action="Delete" asp-route-id="@Model.UserId" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản này không?');" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>