<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Chi Tiêu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* Làm đẹp thanh Menu ngang */
        .navbar-custom {
            background-color: #2c3e50;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .navbar-custom .nav-link {
            color: #ecf0f1 !important;
            font-weight: 500;
            margin: 0 10px;
            transition: 0.3s;
        }
        .navbar-custom .nav-link:hover {
            color: #2ecc71 !important;
        }
        .main-container {
            margin-top: 30px;
            padding: 20px;
        }
    </style>
</head>
<body>
    @if (User.Identity.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">💰 Tiêu dùng thông minh</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Transactions" asp-action="Index"><i class="bi bi-cash-stack"></i> Giao dịch</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Wallets" asp-action="Index"><i class="bi bi-wallet2"></i> Ví</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i> Danh mục</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Budgets" asp-action="Index"><i class="bi bi-piggy-bank"></i> Ngân sách</a>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center">
                        <span class="text-white me-3">Hi, <b class="text-success">@User.Identity.Name</b></span>
                        <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                    </div>
                </div>
            </div>
        </nav>
    }

    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>