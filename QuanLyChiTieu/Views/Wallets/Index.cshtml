@model IEnumerable<QuanLyChiTieu.Models.Wallet>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-success fw-bold">💳 Danh sách ví của tôi</h3>
        <a asp-action="Create" class="btn btn-primary rounded-pill"><i class="bi bi-plus"></i> Tạo ví mới</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm text-white" style="background: linear-gradient(45deg, #2c3e50, #4ca1af); border-radius: 20px;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div>
                                <h5 class="card-title mb-0">@item.WalletName</h5>
                                <small class="text-white-50">Tài khoản chính</small>
                            </div>
                            <i class="bi bi-cpu-fill fs-3"></i>
                        </div>
                        <h3 class="mb-4">**** **** **** @(item.WalletId.Length > 4 ? item.WalletId.Substring(item.WalletId.Length - 4) : "****")</h3>
                        <div class="d-flex justify-content-between">
                            <span>Số dư hiện tại</span>
                            <span class="fw-bold">@(item.Balance.HasValue ? item.Balance.Value.ToString("N0") : "0") đ</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end">
                        <a asp-action="Edit" asp-route-id="@item.WalletId" class="text-white-50 me-2"><i class="bi bi-pencil-square"></i> Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.WalletId" class="text-danger-50"><i class="bi bi-trash"></i> Xóa</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>