@model QuanLyChiTieu.Models.Wallet

@{
    ViewData["Title"] = "Tạo Ví Mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0" style="border-radius: 20px; background: linear-gradient(135deg, #2c3e50 0%, #000000 100%); color: white;">
                <div class="card-header bg-transparent border-0 text-center py-4">
                    <h3 class="fw-bold"><i class="bi bi-wallet2"></i> KÍCH HOẠT VÍ MỚI</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                       
                        <div class="mb-3">
                            <label class="form-label small text-uppercase opacity-75">Tên Ngân Hàng</label>
                            
                            <select asp-for="WalletName" class="form-control bg-dark text-white border-secondary" placeholder="Chọn Ngân Hàng..." required>
                                <option >MBBANK </option>
                                <option >TECHCOMBANK</option>
                                <option>MOMO</option>
                                <option>VIB</option>
                                <option>VIETCOMBANK</option>
                                <option>AGRIBANK</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase opacity-75">Nhập số tiền</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary border-0 text-white">VNĐ</span>
                                <input asp-for="Balance" type="number" class="form-control bg-dark text-white border-secondary" placeholder="0" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold shadow">TẠO VÍ NGAY</button>
                            <a asp-action="Index" class="btn btn-link text-white-50 text-decoration-none">Quay lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>