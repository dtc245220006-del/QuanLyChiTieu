@model IEnumerable<QuanLyChiTieu.Models.Category>

<div class="container mt-4">
    <div class="card shadow border-0" style="border-radius: 15px;">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-tags-fill"></i> Quản lý Danh mục</h4>
            <a asp-controller="Categories" asp-action="Create" class="btn btn-primary rounded-pill shadow-sm">
                <i class="bi bi-plus-lg"></i> Thêm loại mới
            </a>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center p-3 border rounded-3 bg-light shadow-sm">
                            <div>
                                <span class="fw-bold text-dark">@item.CategoryName</span>
                            </div>
                            <div class="btn-group">
                                <a asp-controller="Categories" asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm text-primary p-1"><i class="bi bi-pencil-square"></i></a>
                                <a asp-controller="Categories" asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm text-danger p-1"><i class="bi bi-x-circle-fill"></i></a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>