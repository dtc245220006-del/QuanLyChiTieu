@model QuanLyChiTieu.Models.Budget

@{
    ViewData["Title"] = "Chi tiết Ngân sách";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="mb-0">Ngân sách: <span class="text-primary">@Model.BudgetId</span></h5>
                    <small class="text-muted">@Model.MonthYear</small>
                </div>
                <div class="text-end">
                    <a asp-action="Edit" asp-route-id="@Model.BudgetId" class="btn btn-sm btn-warning me-2"><i class="bi bi-pencil"></i> Sửa</a>
                    <a asp-action="Index" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Người dùng</dt>
                <dd class="col-sm-9">@Model.User?.Username ?? Model.UserId</dd>

                <dt class="col-sm-3">Danh mục</dt>
                <dd class="col-sm-9">@Model.Category?.CategoryName ?? Model.CategoryId</dd>

                <dt class="col-sm-3">Giới hạn</dt>
                <dd class="col-sm-9">@Model.LimitAmount.ToString("C")</dd>

                <dt class="col-sm-3">Tháng/Năm</dt>
                <dd class="col-sm-9">@Model.MonthYear</dd>
            </dl>
        </div>
    </div>
</div>