@model QuanLyChiTieu.Models.Budget

@{
    ViewData["Title"] = "Xóa Ngân sách";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <h5 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận xóa ngân sách</h5>
            <p>Bạn sẽ xóa ngân sách <strong>@Model.BudgetId</strong> cho <strong>@Model.User?.Username ?? Model.UserId</strong>.</p>

            <dl class="row">
                <dt class="col-sm-3">Danh mục</dt>
                <dd class="col-sm-9">@Model.Category?.CategoryName ?? Model.CategoryId</dd>

                <dt class="col-sm-3">Giới hạn</dt>
                <dd class="col-sm-9">@Model.LimitAmount.ToString("C")</dd>
            </dl>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <form asp-action="Delete" asp-route-id="@Model.BudgetId" method="post" onsubmit="return confirm('Xác nhận xóa ngân sách này?');" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa vĩnh viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>