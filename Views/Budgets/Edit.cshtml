@model QuanLyChiTieu.Models.Budget

@{
    ViewData["Title"] = "Chỉnh sửa Ngân sách";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-pencil-square text-primary"></i> Chỉnh sửa Ngân sách</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.BudgetId" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BudgetId" />

                <div class="row gy-3">
                    <div class="col-md-6">
                        <label asp-for="UserId" class="form-label">Người dùng</label>
                        <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LimitAmount" class="form-label">Giới hạn</label>
                        <input asp-for="LimitAmount" class="form-control" />
                        <span asp-validation-for="LimitAmount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MonthYear" class="form-label">Tháng/Năm</label>
                        <input asp-for="MonthYear" class="form-control" placeholder="MM/yyyy" />
                        <span asp-validation-for="MonthYear" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                    <a asp-action="Index" class="btn btn-secondary me-2"><i class="bi bi-x"></i> Hủy</a>
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}