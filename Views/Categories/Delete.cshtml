@model QuanLyChiTieu.Models.Category

@{
    ViewData["Title"] = "Xóa Danh mục";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <h5 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận xóa danh mục</h5>
            <p>Bạn sẽ xóa danh mục <strong>@Model.CategoryName</strong>. Hành động này có thể ảnh hưởng đến giao dịch và ngân sách liên quan.</p>

            <dl class="row">
                <dt class="col-sm-3">CategoryId</dt>
                <dd class="col-sm-9">@Model.CategoryId</dd>

                <dt class="col-sm-3">Loại</dt>
                <dd class="col-sm-9">@Model.Type</dd>
            </dl>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <form asp-action="Delete" asp-route-id="@Model.CategoryId" method="post" onsubmit="return confirm('Xác nhận xóa danh mục này?');" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa vĩnh viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>