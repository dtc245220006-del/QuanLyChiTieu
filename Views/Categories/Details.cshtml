@model QuanLyChiTieu.Models.Category

@{
    ViewData["Title"] = "Chi tiết Danh mục";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="mb-0">@Model.CategoryName</h5>
                    <small class="text-muted">ID: @Model.CategoryId</small>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-sm btn-warning me-2">Sửa</a>
                    <a asp-action="Index" class="btn btn-sm btn-secondary">Quay lại</a>
                </div>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Loại</dt>
                <dd class="col-sm-9">@Model.Type</dd>
            </dl>
        </div>
    </div>
</div>