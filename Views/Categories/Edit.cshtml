@model QuanLyChiTieu.Models.Category

@{
    ViewData["Title"] = "Chỉnh sửa Danh mục";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-tags text-primary"></i> Chỉnh sửa Danh mục</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.CategoryId" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CategoryId" />

                <div class="mb-3">
                    <label asp-for="CategoryName" class="form-label">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Type" class="form-label">Loại</label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                    <button type="submit" class="btn btn-success">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}