@model QuanLyChiTieu.Models.Wallet

@{
    ViewData["Title"] = "Xóa Ví";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <h5 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận xóa ví</h5>
            <p>Bạn sẽ xóa ví <strong>@Model.WalletName</strong> (<span class="text-muted">@Model.User?.Username ?? Model.UserId</span>).</p>

            <dl class="row">
                <dt class="col-sm-3">WalletId</dt>
                <dd class="col-sm-9">@Model.WalletId</dd>

                <dt class="col-sm-3">Số dư</dt>
                <dd class="col-sm-9">@Model.Balance?.ToString("C") ?? "0.00"</dd>
            </dl>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <form asp-action="Delete" asp-route-id="@Model.WalletId" method="post" onsubmit="return confirm('Xác nhận xóa ví này?');" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa vĩnh viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>