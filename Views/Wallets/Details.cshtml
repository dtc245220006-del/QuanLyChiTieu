@model QuanLyChiTieu.Models.Wallet

@{
    ViewData["Title"] = "Chi tiết Ví";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="mb-0">@Model.WalletName</h5>
                    <small class="text-muted">ID: @Model.WalletId</small>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.WalletId" class="btn btn-sm btn-warning me-2">Sửa</a>
                    <a asp-action="Index" class="btn btn-sm btn-secondary">Quay lại</a>
                </div>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Chủ ví</dt>
                <dd class="col-sm-9">@Model.User?.Username ?? Model.UserId</dd>

                <dt class="col-sm-3">Số dư</dt>
                <dd class="col-sm-9">@Model.Balance?.ToString("C") ?? "0.00"</dd>
            </dl>
        </div>
    </div>
</div>