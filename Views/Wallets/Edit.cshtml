@model QuanLyChiTieu.Models.Wallet

@{
    ViewData["Title"] = "Chỉnh sửa Ví";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-wallet2 text-primary"></i> Chỉnh sửa Ví</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.WalletId" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="WalletId" />

                <div class="mb-3">
                    <label asp-for="WalletName" class="form-label">Tên ví</label>
                    <input asp-for="WalletName" class="form-control" />
                    <span asp-validation-for="WalletName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Balance" class="form-label">Số dư</label>
                    <input asp-for="Balance" class="form-control" />
                    <span asp-validation-for="Balance" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserId" class="form-label">Chủ ví</label>
                    <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                    <button type="submit" class="btn btn-success">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}