@model QuanLyChiTieu.Models.Transaction

@{
    ViewData["Title"] = "Xóa Giao dịch";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <h5 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận xóa giao dịch</h5>
            <p>Bạn sẽ xóa giao dịch <strong>@Model.TransactionId</strong> với số tiền <strong>@Model.Amount.ToString("C")</strong>.</p>

            <dl class="row">
                <dt class="col-sm-3">Ví</dt>
                <dd class="col-sm-9">@Model.Wallet?.WalletName ?? Model.WalletId</dd>

                <dt class="col-sm-3">Danh mục</dt>
                <dd class="col-sm-9">@Model.Category?.CategoryName ?? Model.CategoryId</dd>
            </dl>

            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <form asp-action="Delete" asp-route-id="@Model.TransactionId" method="post" onsubmit="return confirm('Xác nhận xóa giao dịch này?');" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa vĩnh viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>