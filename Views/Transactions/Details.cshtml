@model QuanLyChiTieu.Models.Transaction

@{
    ViewData["Title"] = "Chi tiết Giao dịch";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="mb-0">Giao dịch: <span class="text-primary">@Model.TransactionId</span></h5>
                    <small class="text-muted">@Model.TransactionDate?.ToString("g")</small>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.TransactionId" class="btn btn-sm btn-warning me-2">Sửa</a>
                    <a asp-action="Index" class="btn btn-sm btn-secondary">Quay lại</a>
                </div>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Ví</dt>
                <dd class="col-sm-9">@Model.Wallet?.WalletName ?? Model.WalletId</dd>

                <dt class="col-sm-3">Danh mục</dt>
                <dd class="col-sm-9">@Model.Category?.CategoryName ?? Model.CategoryId</dd>

                <dt class="col-sm-3">Số tiền</dt>
                <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>

                <dt class="col-sm-3">Ghi chú</dt>
                <dd class="col-sm-9">@Model.Note</dd>
            </dl>
        </div>
    </div>
</div>