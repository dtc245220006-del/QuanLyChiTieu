@model QuanLyChiTieu.Models.Transaction

@{
    ViewData["Title"] = "Chỉnh sửa Giao dịch";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-cash-stack text-primary"></i> Chỉnh sửa Giao dịch</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.TransactionId" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TransactionId" />

                <div class="row gy-3">
                    <div class="col-md-6">
                        <label asp-for="WalletId" class="form-label">Ví</label>
                        <select asp-for="WalletId" class="form-select" asp-items="ViewBag.WalletId"></select>
                        <span asp-validation-for="WalletId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Amount" class="form-label">Số tiền</label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TransactionDate" class="form-label">Ngày</label>
                        <input asp-for="TransactionDate" class="form-control" type="datetime-local" value="@(Model.TransactionDate.HasValue ? Model.TransactionDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        <span asp-validation-for="TransactionDate" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Note" class="form-label">Ghi chú</label>
                        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Note" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                    <button type="submit" class="btn btn-success">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}